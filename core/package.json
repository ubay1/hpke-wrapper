{
  "name": "@ubay182/hpke-wrapper",
  "version": "1.0.1",
  "description": "HPKE (Hybrid Public Key Encryption) wrapper for meta framework (nextjs, nuxtjs, sveltekit etc.) applications with end-to-end encryption and obfuscation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hpke/chacha20poly1305": "^1.8.0",
    "@hpke/core": "^1.9.0",
    "@hpke/dhkem-x25519": "^1.8.0",
    "uint8array-extras": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "hpke",
    "encryption",
    "e2ee",
    "cryptography",
    "rfc9180"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubay1/hpke-wrapper"
  }
}
